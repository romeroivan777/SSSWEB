# --- Identidad pública del sitio (usado en metadata, JSON-LD y Open Graph) ---
NEXT_PUBLIC_SITE_URL=https://speranza.com.py
NEXT_PUBLIC_SITE_NAME="Speranza Software Solutions"

# --- WhatsApp Business (destino del "Caballo de Troya") ---
# Formato internacional sin signos: 595XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=595984274377

# --- Verificación de motores de búsqueda (opcional) ---
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Backend de automatización (Fase 3 del roadmap: no requerido para el MVP frontend) ---
